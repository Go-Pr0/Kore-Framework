{
  "semantic_mcp": {
    "name": "abstract-fs",
    "mode": "daemon",
    "transport": "streamable-http",
    "host": "127.0.0.1",
    "port": 8800,
    "mount_path": "/mcp",
    "repo_path": "~/.claude-oracle/server",
    "python_path": "~/.claude-oracle/server/.venv/bin/python",
    "module": "abstract_fs_server.server",
    "pythonpath": "src",
    "codex_startup_timeout_sec": 120,
    "embedding_model": "jinaai/jina-code-embeddings-1.5b",
    "semantic_device": "cuda",
    "log_file": "~/.claude/debug/abstract-fs.log"
  }
}
